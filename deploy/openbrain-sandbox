#!/bin/sh
# openbrain - file bridge client for OpenBrain
# Writes /workspace/openbrain-request.json, waits for /workspace/openbrain-response.json
# No wget, curl, python, or network access required — only file read/write.

WORKSPACE=/workspace
REQ="/tmp/openbrain-request.json"
RESP="$WORKSPACE/openbrain-response.json"
RESP_PUSH="$WORKSPACE/openbrain-push.json"
RESP_HEARTBEAT="$WORKSPACE/openbrain-heartbeat.json"
TIMEOUT=10  # seconds to wait for host daemon

CMD="$1"
shift 2>/dev/null || true

# Escape a string for embedding in a JSON string value: backslashes and quotes
# first (kept as the original ordering), then tab/CR/LF turned into their JSON
# escape sequences, then any other raw control byte (0x00-0x1F, 0x7F) is
# stripped so the emitted JSON stays well-formed regardless of input content.
json_escape() {
    printf '%s' "$1" \
        | sed 's/\\/\\\\/g; s/"/\\"/g; s/\t/\\t/g; s/\r/\\r/g' \
        | sed ':a;N;$!ba;s/\n/\\n/g' \
        | tr -d '\000-\010\013\014\016-\037\177'
}

# Clean up any stale files from prior run
rm -f "$REQ" "$RESP"

case "$CMD" in
    search)
        QUERY="$1"; TOP_K="${2:-5}"
        # Validate TOP_K is numeric
        case "$TOP_K" in
            ''|*[!0-9]*) echo '{"ok":false,"error":"top_k must be a positive integer"}' >&2; exit 1 ;;
        esac
        QUERY_ESC="$(json_escape "$QUERY")"
        printf '{"cmd":"search","query":"%s","top_k":%s}' \
            "$QUERY_ESC" "$TOP_K" > "$REQ"
        ;;
    capture)
        CONTENT="$1"; TYPE="${2:-note}"; SOURCE="${3:-openclaw}"
        CONTENT_ESC="$(json_escape "$CONTENT")"
        TYPE_ESC="$(json_escape "$TYPE")"
        SOURCE_ESC="$(json_escape "$SOURCE")"
        printf '{"cmd":"capture","content":"%s","thought_type":"%s","source":"%s"}' \
            "$CONTENT_ESC" "$TYPE_ESC" "$SOURCE_ESC" > "$REQ"
        ;;
    stats)
        printf '{"cmd":"stats"}' > "$REQ"
        ;;
    review)
        DAYS="${1:-7}"
        case "$DAYS" in
            ''|*[!0-9]*) echo '{"ok":false,"error":"days must be a positive integer"}' >&2; exit 1 ;;
        esac
        printf '{"cmd":"review","days":%s}' "$DAYS" > "$REQ"
        ;;
    poll)
        # Read a host-initiated push (openbrain-push.json) if present.
        if [ -f "$RESP_PUSH" ]; then
            cat "$RESP_PUSH"
            echo
            rm -f "$RESP_PUSH"
            exit 0
        fi
        printf '{"ok":false,"error":"no pending push"}\n'
        exit 0
        ;;
    heartbeat)
        # Read the latest heartbeat stats written by watchd (no request needed).
        if [ -f "$RESP_HEARTBEAT" ]; then
            cat "$RESP_HEARTBEAT"
            echo
            exit 0
        fi
        printf '{"ok":false,"error":"no heartbeat yet — is openbrain-watchd running?"}\n'
        exit 0
        ;;
    *)
        echo "Usage: openbrain <search|capture|stats|review|poll|heartbeat> [args]"
        echo ""
        echo "  openbrain search \"query\" [top_k]     -- semantic search"
        echo "  openbrain capture \"content\" [type] [source] -- save a thought"
        echo "  openbrain stats                       -- total thought count"
        echo "  openbrain review [days]               -- recent thoughts by type"
        echo "  openbrain poll                        -- read host-pushed message (if any)"
        echo "  openbrain heartbeat                   -- read latest brain stats heartbeat"
        exit 1
        ;;
esac

# Wait for host daemon to process and write response
i=0
while [ $i -lt $((TIMEOUT * 10)) ]; do
    if [ -f "$RESP" ]; then
        cat "$RESP"
        echo
        rm -f "$RESP"
        exit 0
    fi
    sleep 0.1
    i=$((i + 1))
done

echo '{"ok":false,"error":"timeout: openbrain-watchd not responding — is it running on the host?"}' >&2
rm -f "$REQ"
exit 1
